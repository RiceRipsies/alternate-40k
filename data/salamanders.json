      "name": "Average",
      "rules": []
    },
    {
      "name": "Salamanders",
      "rules": [
        {
          "name": "Protect Civilians",
          "description": "You army may only score VP based on Objectives requiring Objective Markers to be held."
        },
        {
          "name": "Protect What is Already Possessed",
          "description": "Gain +1 VP per completed Objective for Objectives 11-36 once per Turn."
        }
      ]
    }
  ],
